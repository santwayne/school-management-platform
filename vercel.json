{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "routes": [
        {
          "src": "^/(?!assets/)[^.]*$",
          "transforms": [{ "type": "request.path", "op": "set", "args": "/index.html" }]
        }
      ]
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    { "source": "/api(/.*)?", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
