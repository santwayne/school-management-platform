{
  "services": {
    "frontend": { "root": "frontend", "framework": "vite" },
    "backend": { "root": "backend", "entrypoint": "server.js" }
  },
  "rewrites": [
    { "source": "/api(/.*)?", "destination": { "service": "backend" } },
    { "handle": "filesystem" },
    { "source": "/(.*)", "destination": { "service": "frontend", "path": "index.html" } }
  ]
}
