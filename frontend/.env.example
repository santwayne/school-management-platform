VITE_API_URL=http://localhost:5000

# --- Logo upload (Cloudinary) ---
# Create a free account at cloudinary.com, then:
# 1. Copy your Cloud Name from the dashboard
# 2. Go to Settings → Upload → Add upload preset → set to "Unsigned"
# Both vars must be set for the file-upload button to appear in Settings.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
