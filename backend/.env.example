# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/school_mgmt
DATABASE_SSL=false

# --- Redis (BullMQ) ---
REDIS_URL=redis://127.0.0.1:6379

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string

# --- WhatsApp Business Cloud API (Meta) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=choose_your_own_verify_token
WHATSAPP_ABSENCE_TEMPLATE=student_absence_alert
WHATSAPP_GUIDANCE_TEMPLATE=daily_teaching_guidance

# --- Vapi (voice escalation calls) ---
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID_HINDI=
VAPI_ASSISTANT_ID_PUNJABI=

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=

# --- Razorpay (online fee payment links) ---
# Required for /api/payment-links — without these, creating a payment link
# will fail with a clear auth error rather than silently pretending to work.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# From the Razorpay dashboard webhook settings, used to verify that webhook
# calls to /api/payment-links/webhook really came from Razorpay.
RAZORPAY_WEBHOOK_SECRET=

# --- AWS S3 (logo / media uploads) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# --- Misc ---
PORT=5000
ESCALATION_DELAY_MS=7200000
GUIDANCE_CRON=0 7 * * *
